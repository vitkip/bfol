{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash /Applications/XAMPP/xamppfiles/htdocs/bfol/scripts/ftp-upload.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash /Applications/XAMPP/xamppfiles/htdocs/bfol/scripts/full-deploy.sh"
          }
        ]
      }
    ]
  }
}